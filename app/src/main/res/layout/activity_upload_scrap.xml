<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Fabric Scrap"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="16dp"/>

        <!-- Image Preview -->
        <ImageView
            android:id="@+id/ivPreview"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#E8F5E9"
            android:scaleType="centerCrop"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷 Pick Fabric Photo"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="16dp"/>

        <!-- ★ CLOTH TYPE — Type OR Speak ★ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What type of cloth is it?"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:textSize="15sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Type it below OR tap 🎤 to speak it"
                    android:textColor="#888"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <!-- Text field + Mic button side by side -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:hint="e.g. Silk, Cotton, Wool, Polyester..."
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_marginEnd="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etClothType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Mic button to speak cloth type -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVoiceInput"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="🎤"
                        android:padding="0dp"
                        android:backgroundTint="#FF9800"
                        app:cornerRadius="28dp"/>

                </LinearLayout>

                <!-- Quick-select chip shortcuts -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick select:"
                    android:textSize="12sp"
                    android:textColor="#888"
                    android:layout_marginTop="8dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupClothType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSilk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Silk" android:clickable="true"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCotton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cotton" android:clickable="true"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipWool"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wool" android:clickable="true"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPolyester"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Polyester" android:clickable="true"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipJute"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jute" android:clickable="true"/>
                </com.google.android.material.chip.ChipGroup>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Color -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Color (e.g. Red, Blue, Multicolor)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Size -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Size in meters (e.g. 0.5)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Description -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Any extra details?"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Get AI Suggestions button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGetAI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✨ Get AI Design Ideas"
            android:backgroundTint="#FF9800"
            android:layout_marginBottom="12dp"/>

        <!-- AI Suggestions result card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAISuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="#FFF8E1">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ AI Design Ideas for Your Scrap"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    android:textSize="14sp"/>
                <TextView
                    android:id="@+id/tvAISuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#888"
            android:textSize="12sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload Scrap 🚀"
            android:backgroundTint="#2E7D32"
            android:padding="16dp"/>

    </LinearLayout>
</ScrollView>